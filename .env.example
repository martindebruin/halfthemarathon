# Directus
DIRECTUS_SECRET=              # random 32+ char string
DIRECTUS_ADMIN_EMAIL=
DIRECTUS_ADMIN_PASSWORD=
DIRECTUS_PUBLIC_URL=          # e.g. https://directus.yourdomain.com
DIRECTUS_INTERNAL_URL=http://directus:8055
DIRECTUS_TOKEN=               # static API token for webhook-listener and frontend

# Frontend
FRONTEND_URL=                 # e.g. https://yourdomain.com

TELEGRAM_BOT_TOKEN=   # Telegram bot token
TELEGRAM_CHAT_ID=     # Your Telegram chat ID

APP_BEARER_TOKEN=       # random 32+ char string for Android app authentication
ADMIN_TOKEN=           # random 32+ char string for frontend admin access (route renaming)
